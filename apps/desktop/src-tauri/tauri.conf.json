{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "nizamvoice",
  "version": "1.0.16",
  "identifier": "com.nizamvoice.desktop",
  "build": {
    "frontendDist": "../../../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "nizamvoice",
        "width": 1280,
        "height": 840,
        "minWidth": 980,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}



